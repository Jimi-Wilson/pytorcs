# Evaluation-only image for running PPO checkpoints against TORCS.
#
# Build:
#   docker build -f docker/Dockerfile.eval -t torcs-eval .
#
# Run (TORCS race must already be running on Corkscrew with scr_server1 selected):
#   docker run --rm \
#     --network=host \
#     -v /path/to/checkpoints:/checkpoints \
#     -v /path/to/results:/app/results \
#     torcs-eval \
#     --checkpoint /checkpoints/best_model.zip \
#     --episodes 10
#
# With live dashboard (accessible at http://localhost:5001):
#   docker run --rm \
#     --network=host \
#     -v /path/to/checkpoints:/checkpoints \
#     -v /path/to/results:/app/results \
#     torcs-eval \
#     --checkpoint /checkpoints/best_model.zip \
#     --episodes 10 \
#     --serve \
#     --no-browser
#
# Notes:
#   --network=host  gives the container access to TORCS UDP on localhost:3001.
#   --no-browser    required in headless containers (no display available).
#   Results (JSON + HTML report) are written to /app/results inside the container;
#   mount a host directory there to retrieve them.

FROM python:3.10-slim

WORKDIR /app

# Install CPU-only PyTorch first to avoid pulling a multi-GB CUDA wheel
RUN pip install --no-cache-dir torch==2.5.1 \
        --index-url https://download.pytorch.org/whl/cpu

# Copy only what eval needs
COPY eval/requirements.txt /tmp/eval-requirements.txt
RUN pip install --no-cache-dir -r /tmp/eval-requirements.txt

COPY eval/ ./eval/
COPY SACPID/ ./SACPID/

RUN mkdir -p /app/results

ENTRYPOINT ["python", "eval/evaluate.py"]
